    "@types/node": "^20.10.6",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.14",
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "prisma": "^5.7.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
