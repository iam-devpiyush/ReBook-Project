# Test Environment Configuration
# These values should point to a test Supabase instance or local Supabase

# Supabase Configuration for Testing
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=your-test-service-role-key
SUPABASE_ANON_KEY=your-test-anon-key

# Note: For local testing, you can use Supabase CLI:
# 1. Install: npm install -g supabase
# 2. Start local instance: supabase start
# 3. The CLI will output the local URLs and keys to use here
