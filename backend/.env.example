# Database
DATABASE_URL="postgresql://user:password@localhost:5432/bookmarketplace?schema=public"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY_PATH=""
APPLE_CALLBACK_URL="http://localhost:3000/api/auth/apple/callback"

MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_CALLBACK_URL="http://localhost:3000/api/auth/microsoft/callback"

# Session
SESSION_SECRET="your-session-secret-here"
JWT_SECRET="your-jwt-secret-here"

# Server
PORT=3000
NODE_ENV="development"

# Cloud Storage (AWS S3 or Cloudinary)
CLOUD_STORAGE_PROVIDER="s3"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
AWS_S3_BUCKET=""

# Payment Gateway (Stripe or Razorpay)
PAYMENT_PROVIDER="stripe"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Shipping API (Delhivery or Shiprocket)
SHIPPING_PROVIDER="delhivery"
DELHIVERY_API_KEY=""
SHIPROCKET_EMAIL=""
SHIPROCKET_PASSWORD=""

# Meilisearch
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""

# Book Database API
BOOK_API_PROVIDER="google"
GOOGLE_BOOKS_API_KEY=""
