# =============================================================================
# Environment Variables Template
# Copy to .env.local for local development
# =============================================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (https://app.supabase.com/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-api-key

# Payment Gateway — Razorpay
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your-key-id

# Shipping API
SHIPPING_PROVIDER=delhivery
DELHIVERY_API_TOKEN=your-delhivery-api-token
DELHIVERY_API_URL=https://track.delhivery.com

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Supabase Storage
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=book-images
