# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase Configuration
# Get these values from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Razorpay Configuration
# Get these from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-api-key

# Google Gemini Vision API (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key
# 1. Create a Supabase project at https://app.supabase.com
# 2. Go to Settings → API
# 3. Copy the Project URL and anon/public key
# 4. Replace the values above
# 5. Copy this file to .env.local: cp .env.example .env.local
# Instructions:r expose this key in client-side code or commit it to version control
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Instructions:
# 1. Create a Supabase project at https://app.supabase.com
# 2. Go to Settings → API
# 3. Copy the Project URL, anon/public key, and service_role key
# 4. Replace the values above
# 5. Copy this file to .env.local: cp .env.example .env.local
